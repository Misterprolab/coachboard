{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.misterprolab.coachboard",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a472a"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://xvezp9h337yyqdb5pvpko-preview-4200.runable.site/",
      "applicationId": "xvezp9h337yyqdb5pvpko"
    },
    "ios": {
      "bundleIdentifier": "com.misterprolab.coachboard",
      "supportsTablet": true
    },
    "splash": {
