      "themeColor": "#1a472a",
      "backgroundColor": "#1a472a",
      "display": "standalone",
      "orientation": "portrait",
      "icon": "./assets/pwa-icons/icon-512.png",
      "splash": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#1a472a"
      }
